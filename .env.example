# ── Kronos ────────────────────────────────────────────────────────────────────

# Enable distributed multi-node mode (ECS, Kubernetes, multi-replica deployments)
KRONOS_MULTI_NODE=false

# Redis connection name (from config/database.php) used for locking, config store, pub/sub
KRONOS_REDIS_CONNECTION=default

# Queue connection and name for Kronos internal jobs
KRONOS_QUEUE_CONNECTION=redis
KRONOS_QUEUE_NAME=kronos

# Enable the inbound webhook HTTP trigger endpoint
KRONOS_WEBHOOK_ENABLED=false

# Shared secret for authenticating inbound webhook requests (X-Kronos-Secret header)
KRONOS_WEBHOOK_SECRET=

# URL prefix for webhook routes (e.g. "kronos" → POST /kronos/trigger/{workflow})
KRONOS_WEBHOOK_PREFIX=kronos

# Days to retain workflow and schedule run history (null = keep forever)
KRONOS_RETENTION_DAYS=30

# Default timezone applied to all schedules unless overridden per entry
KRONOS_TIMEZONE=UTC

# Enable or disable the Filament UI panel plugin
KRONOS_FILAMENT_ENABLED=true

# Filament panel ID to register Kronos resources into
KRONOS_FILAMENT_PANEL=admin
