    {
        "$schema": "https://getcomposer.org/schema.json",
        "name": "zuqongtech/laravel-kronos",
        "type": "library",
        "description": [],
        "authors": [
            {
                "name": "gideonzozingao",
                "email": "gideongzozingao@gmail.com"
            }
        ],
        "keywords": [
            "laravel",
            "scheduler",
            "workflow",
            "orchestration",
            "dag",
            "cron",
            "rule-engine"
        ],
        "require": {
            "php": "^8.2",
            "laravel/framework": "^11.0|^12.0",
            "symfony/yaml": "^7.0",
            "illuminate/support": "^11.0|^12.0",
            "illuminate/bus": "^11.0|^12.0",
            "illuminate/queue": "^11.0|^12.0",
            "illuminate/redis": "^11.0|^12.0"
        },
        "require-dev": {
            "orchestra/testbench": "^9.0",
            "pestphp/pest": "^2.0",
            "pestphp/pest-plugin-laravel": "^2.0",
            "filament/filament": "^3.0",
            "mockery/mockery": "^1.6"
        },
        "license": "MIT",
        "autoload": {
            "psr-4": {
                "Zuqongtech\\LaravelKronos\\": "src/"
            }
        },
        "autoload-dev": {
            "psr-4": {
                "ZuqongTech\\Kronos\\Tests\\": "tests/"
            }
        },
        "suggest": {
            "filament/filament": "Required for the Kronos UI dashboard (^3.0)",
            "predis/predis": "Required for Redis-backed distributed locking"
